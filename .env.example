# Frontend local API target. The web app falls back to http://localhost:8000,
# but this is useful when you run the frontend outside Docker.
VITE_API_BASE_URL="http://localhost:8000"

# Vite dev-server proxy target for /api (host-only; Docker Compose sets http://api:8000).
# Defaults to http://127.0.0.1:8000 when unset.
# VITE_API_PROXY_TARGET="http://127.0.0.1:8000"

# Add future local config here only when the app starts consuming additional
# local services or authenticated market-data feeds.
